# copie para .env e preencha. nao commite o arquivo .env.
#
# windows e supabase: se aparecer "getaddrinfo failed" no host db....supabase.co,
# a rede pode nao ter ipv6. use a uri do pooler em modo session (ipv4) no supabase.
#
# exemplo de formato (troque regiao, ref e senha):
# DATABASE_URL=postgresql://postgres.REF:SENHA@aws-0-REGIAO.pooler.supabase.com:5432/postgres
#
# conexao direta ao host db.... pode falhar no windows sem ipv6:
# DATABASE_URL=postgresql://postgres:SENHA@db.REF.supabase.co:5432/postgres

DATABASE_URL=

# producao no render: com render.yaml atual vem postgres free e SECRET_KEY gerada.
# supabase no lugar do postgres do render: remova databases no yaml e defina DATABASE_URL aqui ou no painel.
# variaveis render e render_external_hostname o proprio render define.
# dominio proprio (opcional): allowed_hosts e csrf_trusted_origins com https.
