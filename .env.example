# Copie para .env e preencha. Não commite o arquivo .env.
#
# Desenvolvimento local (sem DATABASE_URL usa SQLite):
# DEBUG=True

# PostgreSQL local, Supabase ou Railway (copie do painel):
# DATABASE_URL=postgresql://usuario:senha@host:5432/nome_do_banco

DATABASE_URL=

# Produção (obrigatório fora do Render com SECRET_KEY gerada):
# SECRET_KEY=gere-uma-chave-longa-aleatoria
# DEBUG=False

# Opcional — hosts extras (Railway preenche RAILWAY_PUBLIC_DOMAIN automaticamente):
# ALLOWED_HOSTS=meudominio.com,www.meudominio.com
# CSRF_TRUSTED_ORIGINS=https://meudominio.com,https://www.meudominio.com

# SSL do Postgres (padrão: require; rede interna Railway usa disable automaticamente):
# DATABASE_SSLMODE=require
